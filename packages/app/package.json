{
  "name": "@keiba/app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "競馬期待値分析ツールの Electron デスクトップアプリ(Phase 4)",
  "main": "dist/main/main.cjs",
  "scripts": {
    "dev": "vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build:renderer": "vite build",
    "build:main": "node scripts/build-electron.mjs",
    "build": "pnpm build:renderer && pnpm build:main",
    "build:win": "pnpm build && electron-builder --win --config electron-builder.yml"
  },
  "devDependencies": {
    "@keiba/core": "workspace:*",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^6.0.3",
    "vite": "^6.0.7",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1"
  }
}
